{
  "name": "payla",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Payla — fictional payments dashboard (Mollie-style) with a Cloudflare Worker + D1 mock backend, built to demo the OpenCX Companion agent doing real actions.",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/sync-widget.mjs",
    "build": "pnpm typecheck && vite build",
    "prebuild": "node scripts/sync-widget.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "sync:widget": "node scripts/sync-widget.mjs",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply payla --local",
    "db:migrate:remote": "wrangler d1 migrations apply payla --remote",
    "db:seed:local": "wrangler d1 execute payla --local --file=./migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute payla --remote --file=./migrations/0002_seed.sql",
    "db:reset:local": "wrangler d1 execute payla --local --command \"DELETE FROM refunds; DELETE FROM payments; DELETE FROM payment_links; DELETE FROM disputes; DELETE FROM settlements; DELETE FROM customers; DELETE FROM settings; DELETE FROM balance;\" && pnpm db:seed:local"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@tanstack/react-query": "^5.62.0",
    "hono": "^4.6.14",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wrangler": "^4.0.0"
  }
}
