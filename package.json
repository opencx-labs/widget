{
  "name": "@opencx/widget-monorepo-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "/* ------------------------ SETUP ----------------------- */": "",
    "gen:sdk": "pnpm -F @opencx/widget-core gen:sdk",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "clean:dist": "turbo clean:dist && rm -rf .turbo",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "check": "pnpm clean:dist && pnpm build && pnpm type-check",
    "test": "turbo test",
    "/* --------------------- DEVELOPMENT -------------------- */": "",
    "dev:prepare": "dotenv -- turbo dev:prepare --env-mode",
    "dev": "dotenv -- turbo dev --env-mode",
    "/* --------------------- PUBLISHING --------------------- */": "",
    "x": "pnpm clean:dist && pnpm build && pnpm type-check && pnpm test",
    "cs:pre": "changeset pre enter prerelease",
    "cs:pre:exit": "changeset pre exit",
    "cs": "changeset",
    "csv": "changeset version",
    "csp": "pnpm x && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^20.14.8",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "dotenv-cli": "^10.0.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.5",
    "typescript": "^5.5.4",
    "vite": "^6.4.2",
    "vite-plugin-dts": "4.0.3",
    "vite-plugin-externalize-deps": "^0.9.0",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^3.0.2"
  },
  "pnpm": {
    "overrides": {
      "mdast-util-gfm-autolink-literal": "2.0.0",
      "ajv@<6.14.0": "^6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "^8.18.0",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "esbuild@<0.25.0": "^0.25.0",
      "flatted@<3.4.2": "^3.4.2",
      "glob@>=10.2.0 <10.5.0": "^10.5.0",
      "js-yaml@<3.14.2": "^3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": "^4.1.1",
      "lodash@<4.18.0": "^4.18.0",
      "mdast-util-to-hast@<13.2.1": "^13.2.1",
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "^5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "postcss@<8.5.10": "^8.5.10",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "tmp@<0.2.4": "^0.2.4",
      "uuid@>=11.0.0 <11.1.1": "^11.1.1",
      "vite@<6.4.2": "^6.4.2",
      "yaml@>=2.0.0 <2.8.3": "^2.8.3"
    }
  }
}
